{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Welcome to MkDocs","text":"<p>For full documentation visit mkdocs.org.</p>"},{"location":"#commands","title":"Commands","text":"<ul> <li><code>mkdocs new [dir-name]</code> - Create a new project.</li> <li><code>mkdocs serve</code> - Start the live-reloading docs server.</li> <li><code>mkdocs build</code> - Build the documentation site.</li> <li><code>mkdocs -h</code> - Print help message and exit.</li> </ul>"},{"location":"#project-layout","title":"Project layout","text":"<pre><code>mkdocs.yml    # The configuration file.\ndocs/\n    index.md  # The documentation homepage.\n    ...       # Other markdown pages, images and other files.\n</code></pre>"},{"location":"linux/luna/","title":"Luna","text":""},{"location":"linux/luna/#_1","title":"\u57fa\u672c\u4fe1\u606f","text":"<ul> <li>\u7cfb\u7edf\uff1adebian11</li> <li>\u7528\u9014\uff1a\u5bb6\u7528\u670d\u52a1\u5668</li> <li>IP\uff1a192.168.9.200</li> </ul>"},{"location":"linux/luna/#_2","title":"\u5df2\u90e8\u7f72\u670d\u52a1","text":"<ul> <li>Docker</li> <li>Tg-singer</li> </ul>"},{"location":"linux/luna/%E5%9F%BA%E7%A1%80%E8%AE%BE%E7%BD%AE/","title":"\u6d4b\u8bd5","text":"<p>\u662f\u5426\u66f4\u65b0</p>"},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/","title":"\u670d\u52a1\u5668\u5f00\u673a/\u5173\u673a Ntfy \u63a8\u9001\u63d0\u9192\u914d\u7f6e\u6587\u6863","text":""},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/#_1","title":"\u6587\u6863\u8bf4\u660e","text":"<ul> <li> <p>\u529f\u80fd\uff1a\u670d\u52a1\u5668\u5f00\u673a\u5b8c\u6210\u3001\u5173\u673a/\u91cd\u542f\u65f6\uff0c\u81ea\u52a8\u901a\u8fc7 Ntfy \u63a8\u9001\u901a\u77e5\u5230\u5b89\u5353\u624b\u673a</p> </li> <li> <p>\u9002\u914d\u73af\u5883\uff1aUbuntu/Debian \u7cfb Linux</p> </li> <li> <p>\u6838\u5fc3\u4f18\u52bf\uff1a\u89c4\u907f\u7cfb\u7edf\u4ee3\u7406\u3001\u7f51\u7edc\u8d85\u65f6\u5bb9\u9519\u3001\u4e0d\u5f71\u54cd\u5f00\u5173\u673a\u901f\u5ea6\u3001\u5168\u7a0b\u540e\u53f0\u81ea\u542f</p> </li> <li> <p>\u7f16\u8f91\u5668\uff1a\u5168\u7a0b\u4f7f\u7528 vim\uff08\u66ff\u4ee3 nano\uff09</p> </li> <li> <p>\u4e13\u5c5e Ntfy \u4e3b\u9898\uff1a<code>xxxxxxxxx(\u66ff\u6362\u4e3a\u81ea\u5df1\u7684)</code></p> </li> </ul>"},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/#_2","title":"\u524d\u7f6e\u51c6\u5907","text":"<ol> <li> <p>\u5b89\u5353\u624b\u673a\u5b89\u88c5 Ntfy \u5ba2\u6237\u7aef\uff0c\u8ba2\u9605\u4e3b\u9898\uff1a<code>xxxxxxxx(\u8f93\u5165\u81ea\u5df1\u7684)</code></p> </li> <li> <p>\u670d\u52a1\u5668\u5df2\u5b89\u88c5 curl\uff1a<code>sudo apt install curl -y</code></p> </li> <li> <p>\u670d\u52a1\u5668\u5df2\u6e05\u7406\u65e0\u6548\u4ee3\u7406\u914d\u7f6e\uff0c\u811a\u672c\u5185\u7f6e\u6e05\u7a7a\u4ee3\u7406\u903b\u8f91\uff0c\u675c\u7edd\u8fde\u63a5\u8d85\u65f6</p> </li> </ol>"},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/#_3","title":"\u4e00\u3001\u914d\u7f6e\u670d\u52a1\u5668\u5f00\u673a\u63a8\u9001\u63d0\u9192","text":""},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/#1","title":"1. \u7f16\u5199\u5f00\u673a\u901a\u77e5\u811a\u672c","text":"<p>\u521b\u5efa\u5f00\u673a\u63a8\u9001\u811a\u672c\u6587\u4ef6\uff1a</p> <pre><code>sudo vim /usr/local/bin/boot-notify.sh\n</code></pre> <p>\u7c98\u8d34\u4ee5\u4e0b\u5b8c\u6574\u811a\u672c\u5185\u5bb9\uff08\u5df2\u4f18\u5316\u7f51\u7edc\u7b49\u5f85\u3001\u6e05\u7a7a\u4ee3\u7406\u3001\u4fe1\u606f\u5c55\u793a\uff09\uff1a</p> <pre><code>#!/bin/bash\n\n# Ntfy \u4e13\u5c5e\u4e3b\u9898\nTOPIC=\"(\u8f93\u5165\u81ea\u5df1\u7684\u4e3b\u9898)\"\nNTFY_URL=\"https://ntfy.sh/$TOPIC\"\n\n# \u7b49\u5f85\u7cfb\u7edf\u7f51\u7edc\u5b8c\u5168\u521d\u59cb\u5316\uff08\u89e3\u51b3\u5f00\u673a\u65e0\u7f51\u63a8\u9001\u5931\u8d25\u95ee\u9898\uff09\nsleep 20\n\n# \u63a8\u9001\u6d88\u606f\u5185\u5bb9\uff08\u5c55\u793a\u4e3b\u673a\u540d\u3001IP\u3001\u5f00\u673a\u65f6\u95f4\uff09\nMSG=\"\u2705 \u670d\u52a1\u5668\u5f00\u673a\u5b8c\u6210\n\u4e3b\u673a\u540d: $(hostname)\nIP: $(hostname -I)\n\u65f6\u95f4: $(date '+%Y-%m-%d %H:%M:%S')\"\n\n# \u5f3a\u5236\u6e05\u7a7a\u5168\u5c40\u4ee3\u7406\uff0c\u907f\u514d\u63a8\u9001\u8d70\u4ee3\u7406\u8d85\u65f6\nunset http_proxy https_proxy all_proxy\n\n# \u53d1\u9001\u63a8\u9001\uff083\u79d2\u8d85\u65f6\u515c\u5e95\uff0c\u4e0d\u963b\u585e\u7cfb\u7edf\uff09\ncurl -m 3 \\\n     -H \"Title: \u670d\u52a1\u5668\u5f00\u673a\u63d0\u9192\" \\\n     -H \"Priority: high\" \\\n     -d \"$MSG\" \\\n     \"$NTFY_URL\"\n</code></pre> <p>vim \u4fdd\u5b58\u9000\u51fa\u64cd\u4f5c\uff1a\u6309 <code>Esc</code> \u2192 \u8f93\u5165 <code>:wq</code> \u2192 \u56de\u8f66</p>"},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/#2","title":"2. \u6dfb\u52a0\u811a\u672c\u6267\u884c\u6743\u9650","text":"<pre><code>sudo chmod +x /usr/local/bin/boot-notify.sh\n</code></pre>"},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/#3-systemd","title":"3. \u521b\u5efa systemd \u5f00\u673a\u670d\u52a1","text":"<p>\u521b\u5efa\u7cfb\u7edf\u670d\u52a1\u914d\u7f6e\u6587\u4ef6\uff1a</p> <pre><code>sudo vim /etc/systemd/system/boot-notify.service\n</code></pre> <p>\u7c98\u8d34\u4ee5\u4e0b\u670d\u52a1\u914d\u7f6e\uff1a</p> <pre><code>[Unit]\nDescription=\u670d\u52a1\u5668\u5f00\u673a Ntfy \u63a8\u9001\u901a\u77e5\u670d\u52a1\nAfter=network-online.target\n\n[Service]\nType=oneshot\nExecStart=/usr/local/bin/boot-notify.sh\nUser=yuuki\n\n[Install]\nWantedBy=multi-user.target\n</code></pre> <p>\u4fdd\u5b58\u9000\u51fa\uff08<code>Esc</code> \u2192 <code>:wq</code> \u2192 \u56de\u8f66\uff09</p>"},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/#4","title":"4. \u542f\u7528\u5e76\u6d4b\u8bd5\u5f00\u673a\u670d\u52a1","text":"<pre><code># \u91cd\u8f7d\u7cfb\u7edf\u670d\u52a1\u914d\u7f6e\nsudo systemctl daemon-reload\n\n# \u8bbe\u7f6e\u5f00\u673a\u81ea\u542f\nsudo systemctl enable boot-notify\n\n# \u624b\u52a8\u6d4b\u8bd5\u63a8\u9001\uff08\u65e0\u9700\u91cd\u542f\u670d\u52a1\u5668\uff09\nsudo systemctl start boot-notify\n\n# \u67e5\u770b\u670d\u52a1\u8fd0\u884c\u65e5\u5fd7\uff08\u6392\u67e5\u62a5\u9519\uff09\njournalctl -u boot-notify\n</code></pre> <p>\u6267\u884c\u6d4b\u8bd5\u547d\u4ee4\u540e\uff0c\u624b\u673a\u6536\u5230\u63a8\u9001\u5373\u4ee3\u8868\u914d\u7f6e\u6210\u529f\u3002</p>"},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/#_4","title":"\u4e8c\u3001\u914d\u7f6e\u670d\u52a1\u5668\u5173\u673a/\u91cd\u542f\u63a8\u9001\u63d0\u9192","text":""},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/#1_1","title":"1. \u7f16\u5199\u5173\u673a\u901a\u77e5\u811a\u672c","text":"<p>\u521b\u5efa\u5173\u673a\u63a8\u9001\u811a\u672c\u6587\u4ef6\uff1a</p> <pre><code>sudo vim /usr/local/bin/shutdown-notify.sh\n</code></pre> <p>\u7c98\u8d34\u4ee5\u4e0b\u5b8c\u6574\u811a\u672c\u5185\u5bb9\uff1a</p> <pre><code>#!/bin/bash\n\n# Ntfy \u4e13\u5c5e\u4e3b\u9898\nTOPIC=\"(\u8f93\u5165\u81ea\u5df1\u7684\u4e3b\u9898)\"\nNTFY_URL=\"https://ntfy.sh/$TOPIC\"\n\n# \u63a8\u9001\u6d88\u606f\u5185\u5bb9\nMSG=\"\u26a0\ufe0f \u670d\u52a1\u5668\u5373\u5c06\u5173\u673a/\u91cd\u542f\n\u4e3b\u673a\u540d: $(hostname)\n\u65f6\u95f4: $(date '+%Y-%m-%d %H:%M:%S')\"\n\n# \u5f3a\u5236\u6e05\u7a7a\u5168\u5c40\u4ee3\u7406\nunset http_proxy https_proxy all_proxy\n\n# \u5feb\u901f\u63a8\u9001\uff083\u79d2\u8d85\u65f6\uff0c\u4e0d\u963b\u585e\u5173\u673a\u6d41\u7a0b\uff09\ncurl -m 3 \\\n     -H \"Title: \u670d\u52a1\u5668\u5173\u673a\u63d0\u9192\" \\\n     -H \"Priority: high\" \\\n     -d \"$MSG\" \\\n     \"$NTFY_URL\"\n</code></pre> <p>\u4fdd\u5b58\u9000\u51fa\uff08<code>Esc</code> \u2192 <code>:wq</code> \u2192 \u56de\u8f66\uff09</p>"},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/#2_1","title":"2. \u6dfb\u52a0\u811a\u672c\u6267\u884c\u6743\u9650","text":"<pre><code>sudo chmod +x /usr/local/bin/shutdown-notify.sh\n</code></pre>"},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/#3-systemd_1","title":"3. \u521b\u5efa systemd \u5173\u673a\u670d\u52a1","text":"<p>\u521b\u5efa\u5173\u673a\u4e13\u5c5e\u670d\u52a1\u914d\u7f6e\uff1a</p> <pre><code>sudo vim /etc/systemd/system/shutdown-notify.service\n</code></pre> <p>\u7c98\u8d34\u4ee5\u4e0b\u914d\u7f6e\uff08\u6838\u5fc3\uff1a\u4e0d\u963b\u585e\u5173\u673a\u6d41\u7a0b\u3001\u4f18\u5148\u6267\u884c\u63a8\u9001\uff09\uff1a</p> <pre><code>[Unit]\nDescription=\u670d\u52a1\u5668\u5173\u673a/\u91cd\u542f Ntfy \u63a8\u9001\u901a\u77e5\u670d\u52a1\nDefaultDependencies=no\nBefore=shutdown.target reboot.target halt.target\n\n[Service]\nType=oneshot\nExecStart=/usr/local/bin/shutdown-notify.sh\nTimeoutSec=10\n\n[Install]\nWantedBy=shutdown.target reboot.target halt.target\n</code></pre> <p>\u4fdd\u5b58\u9000\u51fa</p>"},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/#4_1","title":"4. \u542f\u7528\u5173\u673a\u63a8\u9001\u670d\u52a1","text":"<pre><code># \u91cd\u8f7d\u670d\u52a1\u914d\u7f6e\nsudo systemctl daemon-reload\n\n# \u7ed1\u5b9a\u5173\u673a/\u91cd\u542f\u4e8b\u4ef6\u81ea\u89e6\u53d1\nsudo systemctl enable shutdown-notify\n\n# \u624b\u52a8\u6d4b\u8bd5\u811a\u672c\nsudo /usr/local/bin/shutdown-notify.sh\n\n# \u67e5\u770b\u8fd0\u884c\u65e5\u5fd7\njournalctl -u shutdown-notify\n</code></pre>"},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/#_5","title":"\u4e09\u3001\u5173\u952e\u4f18\u5316\u8bf4\u660e\uff08\u5fc5\u770b\uff09","text":"<ul> <li> <p>\u4e0d\u5f71\u54cd\u5f00\u5173\u673a\u901f\u5ea6\uff1a\u5173\u673a\u670d\u52a1\u91c7\u7528\u5e76\u884c\u6267\u884c\u6a21\u5f0f\uff0ccurl \u8bbe\u7f6e3\u79d2\u8d85\u65f6\u3001\u670d\u52a110\u79d2\u515c\u5e95\u8d85\u65f6\uff0c\u4e0d\u4f1a\u5361\u6b7b\u7cfb\u7edf</p> </li> <li> <p>\u4ee3\u7406\u5f7b\u5e95\u89c4\u907f\uff1a\u6240\u6709\u811a\u672c\u5185\u7f6e <code>unset</code> \u6e05\u7a7a\u4ee3\u7406\u547d\u4ee4\uff0c\u5b8c\u7f8e\u89e3\u51b3\u4e4b\u524d Clash \u4ee3\u7406\u8d85\u65f6\u95ee\u9898</p> </li> <li> <p>\u5f00\u673a\u5bb9\u9519\uff1a\u5f00\u673a\u811a\u672c\u5ef6\u8fdf20\u79d2\u6267\u884c\uff0c\u7b49\u5f85\u7f51\u5361\u3001\u7f51\u7edc\u670d\u52a1\u5b8c\u5168\u521d\u59cb\u5316\uff0c\u675c\u7edd\u5f00\u673a\u65e0\u7f51\u63a8\u9001\u5931\u8d25</p> </li> <li> <p>\u4f18\u5148\u7ea7\u9002\u914d\uff1a\u63a8\u9001\u8bbe\u7f6e\u9ad8\u4f18\u5148\u7ea7\uff0c\u624b\u673a\u5f39\u7a97\u63d0\u9192\uff0c\u548c Bark \u5f3a\u63d0\u9192\u6548\u679c\u4e00\u81f4</p> </li> </ul>"},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/#_6","title":"\u56db\u3001\u5e38\u7528\u8fd0\u7ef4\u547d\u4ee4","text":"<pre><code># \u5173\u95ed\u5f00\u673a\u63a8\u9001\u81ea\u542f\nsudo systemctl disable boot-notify\n\n# \u5173\u95ed\u5173\u673a\u63a8\u9001\u81ea\u542f\nsudo systemctl disable shutdown-notify\n\n# \u5b9e\u65f6\u67e5\u770b\u5f00\u673a\u63a8\u9001\u65e5\u5fd7\njournalctl -fu boot-notify\n\n# \u5b9e\u65f6\u67e5\u770b\u5173\u673a\u63a8\u9001\u65e5\u5fd7\njournalctl -fu shutdown-notify\n</code></pre>"},{"location":"linux/luna/%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%BC%80%E5%85%B3%E6%9C%BANtfy%E6%8E%A8%E9%80%81/#_7","title":"\u4e94\u3001\u6700\u7ec8\u6548\u679c","text":"<ol> <li> <p>\u670d\u52a1\u5668\u5f00\u673a\u5b8c\u6210\u540e20\u79d2\uff0c\u624b\u673a\u6536\u5230\u3010\u670d\u52a1\u5668\u5f00\u673a\u63d0\u9192\u3011\u63a8\u9001\uff0c\u5305\u542b\u4e3b\u673a\u4fe1\u606f\u3001\u5f00\u673a\u65f6\u95f4</p> </li> <li> <p>\u670d\u52a1\u5668\u6267\u884c\u5173\u673a/\u91cd\u542f\u77ac\u95f4\uff0c\u624b\u673a\u6536\u5230\u3010\u670d\u52a1\u5668\u5173\u673a\u63d0\u9192\u3011\u63a8\u9001</p> </li> <li> <p>\u5168\u7a0b\u65e0\u5361\u987f\u3001\u65e0\u62a5\u9519\uff0c\u7a33\u5b9a\u590d\u7528\u4e2a\u4eba\u4e13\u5c5e Ntfy \u901a\u9053</p> </li> </ol> <p>\uff08\u6ce8\uff1a\u6587\u6863\u90e8\u5206\u5185\u5bb9\u53ef\u80fd\u7531 AI \u751f\u6210\uff09</p>"}]}